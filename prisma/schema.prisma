generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model Season {
  id       String  @id
  year     Int
  name     String
  gameName String
  current  Boolean @default(false)
  events   Event[]
}

model Team {
  number      Int          @id
  name        String
  city        String
  state       String
  country     String
  rookieYear  Int
  teamSeasons TeamSeason[]
}

model TeamSeason {
  id         String  @id @default(cuid())
  seasonId   String
  teamNumber Int
  notes      String?
  team       Team    @relation(fields: [teamNumber], references: [number])

  @@unique([seasonId, teamNumber])
}

model Event {
  id        String   @id @default(cuid())
  code      String
  seasonId  String
  name      String
  city      String
  state     String
  venue     String
  startDate DateTime
  endDate   DateTime
  season    Season   @relation(fields: [seasonId], references: [id])
  matches   Match[]

  @@unique([seasonId, code])
}

model FtcApiCache {
  key       String   @id
  endpoint  String
  payload   String
  fetchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FtcSyncLog {
  id        String   @id @default(cuid())
  scope     String
  season    String?
  eventCode String?
  status    String
  message   String
  createdAt DateTime @default(now())
}

model Match {
  id          String          @id
  seasonId    String
  eventId     String
  level       String
  matchNumber Int
  scheduledAt DateTime
  status      String
  event       Event           @relation(fields: [eventId], references: [id])
  alliances   MatchAlliance[]
}

model MatchAlliance {
  id      String      @id @default(cuid())
  matchId String
  color   String
  score   Int
  auto    Int?
  teleop  Int?
  endgame Int?
  rp      Int?
  match   Match       @relation(fields: [matchId], references: [id])
  teams   MatchTeam[]
}

model MatchTeam {
  id              String        @id @default(cuid())
  matchAllianceId String
  teamNumber      Int
  station         Int?
  matchAlliance   MatchAlliance @relation(fields: [matchAllianceId], references: [id])
}

model Ranking {
  id         String @id @default(cuid())
  seasonId   String
  eventCode  String
  teamNumber Int
  rank       Int
  wins       Int
  losses     Int
  ties       Int
  rp         Float
  tbp        Float
}

model Award {
  id         String @id @default(cuid())
  seasonId   String
  eventCode  String
  teamNumber Int?
  name       String
  recipient  String
}

model TeamEventStats {
  id         String @id @default(cuid())
  seasonId   String
  eventCode  String
  teamNumber Int
  avgScore   Float
  record     String
}

model OPRResult {
  id         String  @id @default(cuid())
  seasonId   String
  eventCode  String?
  teamNumber Int
  opr        Float
  autoOpr    Float
  teleopOpr  Float
  endgameOpr Float
}

model ScoutingReport {
  id          String  @id @default(cuid())
  seasonId    String
  eventCode   String
  matchNumber Int
  teamNumber  Int
  alliance    String
  auto        Int
  teleop      Int
  endgame     Int
  penalties   Int
  disabled    Boolean
  driverSkill Int
  reliability Int
  defense     Int
  overall     Int
  notes       String
}

model VideoUpload {
  id          String          @id @default(cuid())
  title       String
  seasonId    String
  eventCode   String
  matchNumber Int
  teamNumber  Int?
  url         String
  events      TimelineEvent[]
}

model TimelineEvent {
  id         String      @id @default(cuid())
  videoId    String
  timestamp  Float
  type       String
  teamNumber Int?
  alliance   String?
  notes      String
  video      VideoUpload @relation(fields: [videoId], references: [id])
}

model StreamLink {
  id        String  @id @default(cuid())
  seasonId  String
  eventCode String?
  label     String
  url       String
  field     String?
}

model FavoriteTeam {
  id         String @id @default(cuid())
  userId     String
  teamNumber Int
}

model Picklist {
  id        String          @id @default(cuid())
  seasonId  String
  eventCode String
  name      String
  entries   PicklistEntry[]
}

model PicklistEntry {
  id         String   @id @default(cuid())
  picklistId String
  teamNumber Int
  rank       Int
  notes      String
  picklist   Picklist @relation(fields: [picklistId], references: [id])
}

model AIAnalysis {
  id        String   @id @default(cuid())
  kind      String
  prompt    String
  response  String
  createdAt DateTime @default(now())
}

model AutoscoreJob {
  id          String                @id @default(cuid())
  title       String
  seasonId    String
  eventCode   String?
  status      String
  confidence  Float
  suggestions AutoscoreSuggestion[]
}

model AutoscoreSuggestion {
  id         String       @id @default(cuid())
  jobId      String
  timestamp  Float
  type       String
  confidence Float
  status     String
  job        AutoscoreJob @relation(fields: [jobId], references: [id])
}
