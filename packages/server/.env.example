# Copy this file to packages/server/.env and fill in real values locally.
# Do not commit packages/server/.env.

# Base64 of "YOUR_USERNAME:YOUR_API_KEY" with no trailing newline.
# Generate on Mac/Linux with: echo -n "YOUR_USERNAME:YOUR_API_KEY" | base64
FTC_API_KEY="BASE64_ENCODED_FTC_EVENTS_USERNAME_COLON_AUTHORIZATION_KEY"

# Local Postgres connection URL.
DATABASE_URL="postgres://ftcscoutuser:ftcscoutpassword@localhost:5432/ftcscoutdb"

# Backend server port. The local web example expects localhost:4000.
PORT=4000

# Header name shared with packages/web/.env PUBLIC_FRONTEND_CODE.
# Use any non-secret string, but it must match exactly in both env files.
FRONTEND_CODE="local-dev-frontend-code"

# Development switches.
# For production, set these intentionally based on the deployment target.
LOGGING=0
SYNC_DB=1
SYNC_API=1
CACHE_REQ=1

# Live-update notes:
# - FTC_API_KEY is required for the backend to fetch fresh FTC data.
# - SYNC_API=1 keeps the backend polling and loading updates.
# - DATABASE_URL must point at the persistent production database.
# - The frontend request header is now built in; no env var needed.

# Timeout for database requests in ms, ish.
DB_TIMEOUT=5000
