# Copy this file to packages/server/.env and fill in real values locally.
# Do not commit packages/server/.env.

# Base64 of "YOUR_USERNAME:YOUR_API_KEY" with no trailing newline.
# Generate on Mac/Linux with: echo -n "YOUR_USERNAME:YOUR_API_KEY" | base64
FTC_API_KEY="BASE64_ENCODED_FTC_EVENTS_USERNAME_COLON_AUTHORIZATION_KEY"

# Database URL - MongoDB Atlas in production
# Local dev can use a local MongoDB instance or the same Atlas cluster.
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/ftcscout?retryWrites=true&w=majority"

# Non-secret defaults (hard-coded per request)
# Public frontend code (must match PUBLIC_FRONTEND_CODE in web when running locally)
FRONTEND_CODE="local-dev-frontend-code"

# Backend public origin (no protocol)
PUBLIC_SERVER_ORIGIN="localhost:4000"

# Runtime flags
LOGGING=true
SYNC_DB=1
SYNC_API=1
CACHE_REQ=0
DB_TIMEOUT=5000
RESPONSE_CACHE_SECONDS=0

# All other settings are hardcoded:
# - PORT: 8080 (prod) / 4000 (dev)
# - LOGGING: true
# - SYNC_DB: true (continuously sync from FTC API)
# - SYNC_API: true (continuously poll FTC API)
# - RESPONSE_CACHE_SECONDS: 0 (always fresh data on reload)
# - DB_TIMEOUT: 5000ms
