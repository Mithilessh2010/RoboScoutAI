# Copy this file to packages/server/.env and fill in real values locally.
# Do not commit packages/server/.env.

# Base64 of "YOUR_USERNAME:YOUR_API_KEY" with no trailing newline.
# Generate on Mac/Linux with: echo -n "YOUR_USERNAME:YOUR_API_KEY" | base64
FTC_API_KEY="BASE64_ENCODED_FTC_EVENTS_USERNAME_COLON_AUTHORIZATION_KEY"

# Database URL - auto-detects type from prefix
# Local (SQLite - no setup needed): sqlite:./ftcscout.db
# Production (Postgres on Fly): postgres://user:password@host:5432/db
DATABASE_URL="sqlite:./ftcscout.db"

# All other settings are hardcoded:
# - PORT: 8080 (prod) / 4000 (dev)
# - LOGGING: true
# - SYNC_DB: true (continuously sync from FTC API)
# - SYNC_API: true (continuously poll FTC API)
# - RESPONSE_CACHE_SECONDS: 0 (always fresh data on reload)
# - DB_TIMEOUT: 5000ms
