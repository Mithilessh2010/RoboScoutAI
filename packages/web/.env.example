# Copy this file to packages/web/.env.local and fill in real values locally.
# Do not commit packages/web/.env.local

# FTC Events API v2.0 credentials
# Get these from https://www.firstinspires.org/ftc-events-api
# These are sensitive - never commit real values.
FTC_EVENTS_USERNAME="your_username_here"
FTC_EVENTS_AUTH_KEY="your_authorization_key_here"

# Backend GraphQL origin (no protocol, no trailing slash)
# Examples:
#   LOCAL: localhost:4000
#   FLY: my-backend.fly.dev
PUBLIC_SERVER_ORIGIN="api.ftcscout.org"
PUBLIC_FRONTEND_CODE="production-frontend-code"
# Public frontend code (non-secret, must match server FRONTEND_CODE when running locally)
PUBLIC_FRONTEND_CODE="local-dev-frontend-code"

# FTC Events API base URL (non-secret)
FTC_EVENTS_API_BASE_URL="https://ftc-api.firstinspires.org/v2.0"

# Autoscore worker used in production for video upload, YOLO processing, and video playback
PUBLIC_VIDEO_PROCESSING_API_URL="https://roboscoutai-autoscore-worker.fly.dev"
# Maximum time to wait for the worker to prepare a playable video before failing the UI
PUBLIC_AUTOSCORE_PREP_TIMEOUT_MS="900000"
AUTOSCORE_WORKER_SECRET=""
