# Copy this file to packages/web/.env and fill in local values.
# Do not commit packages/web/.env.

# Backend origin without protocol. Local server default is localhost:4000.
PUBLIC_SERVER_ORIGIN="localhost:4000"

# Header name shared with packages/server/.env FRONTEND_CODE.
# This value is public frontend config, so do not use a real secret.
PUBLIC_FRONTEND_CODE="local-dev-frontend-code"
