# Copy this file to packages/web/.env.local and fill in local values.
# Do not commit packages/web/.env.local

# FTC Events API v2.0 credentials used by SvelteKit API routes in packages/web/src/routes/api/ftc.
# Get these from https://www.firstinspires.org/ftc-events-api
# These are sensitive - never commit real values.
FTC_EVENTS_USERNAME="your_username_here"
FTC_EVENTS_AUTH_KEY="your_authorization_key_here"
FTC_EVENTS_API_BASE_URL="https://ftc-api.firstinspires.org/v2.0"

# Optional overrides for the backend GraphQL origin.
# If omitted, the app uses localhost:4000 in dev and api.ftcscout.org in prod.
# For Fly.io backend + Vercel frontend, set this to your Fly app host (no protocol),
# for example: my-backend.fly.dev
# PUBLIC_SERVER_ORIGIN="localhost:4000"
